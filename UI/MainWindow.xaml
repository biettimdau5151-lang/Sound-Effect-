<mah:MetroWindow
	x:Class="SoundEffect.UI.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
	xmlns:ViewModels="clr-namespace:SoundEffect.UI.ViewModels"
	xmlns:WpfUiConveter="clr-namespace:SoundEffect.Lib.Converters"
	xmlns:WpfUiControls="clr-namespace:SoundEffect.Lib.Controls"
	Title="Sound Live Effect"
	Width="290"
	Height="520"
	MinWidth="260"
	MinHeight="500"
	WindowStartupLocation="CenterScreen"
	GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
	BorderBrush="{DynamicResource MahApps.Brushes.Accent}"
	BorderThickness="1"
	Loaded="Window_Loaded"
	Closed="Window_Closed">
	<FrameworkElement.DataContext>
		<ViewModels:MainWVM />
	</FrameworkElement.DataContext>
	<Window.Resources>
		<ResourceDictionary>
			<WpfUiConveter:BooleanToVisibleConverter
				x:Key="BooleanFalseToHiddenConverter" />
			<WpfUiConveter:BooleanToVisibleConverter
				IsReversed="True"
				x:Key="BooleanTrueToHiddenConverter" />

			<Style x:Key="EffectButtonStyle" TargetType="Button">
				<Setter Property="Width" Value="80" />
				<Setter Property="Height" Value="42" />
				<Setter Property="Margin" Value="4" />
				<Setter Property="Cursor" Value="Hand" />
				<Setter Property="Foreground" Value="White" />
				<Setter Property="BorderThickness" Value="0" />
				<Setter Property="HorizontalAlignment" Value="Center" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="Button">
							<Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
								<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter TargetName="border" Property="Background" Value="#E53935" />
								</Trigger>
								<Trigger Property="IsPressed" Value="True">
									<Setter TargetName="border" Property="Background" Value="#B71C1C" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>

			<Style x:Key="GroupButtonStyle" TargetType="Button">
				<Setter Property="Width" Value="55" />
				<Setter Property="Height" Value="26" />
				<Setter Property="Margin" Value="1" />
				<Setter Property="Cursor" Value="Hand" />
				<Setter Property="Foreground" Value="White" />
				<Setter Property="BorderThickness" Value="0" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="Button">
							<Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
								<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter TargetName="border" Property="Opacity" Value="0.85" />
								</Trigger>
								<Trigger Property="IsPressed" Value="True">
									<Setter TargetName="border" Property="Background" Value="#E53935" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
		</ResourceDictionary>
	</Window.Resources>
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="80" />
			<RowDefinition />
			<RowDefinition Height="30" />
		</Grid.RowDefinitions>

		<Border Grid.Row="0" Background="{DynamicResource MahApps.Brushes.Accent}" Padding="5">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition />
					<RowDefinition />
				</Grid.RowDefinitions>
				<Grid Row="0">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="65" />
					</Grid.ColumnDefinitions>
					<mah:ToggleSwitch
						Grid.Column="0"
						Name="cb_topMost"
						VerticalAlignment="Center"
						Content="Luôn Hiện"
						Foreground="White"
						IsOn="{Binding IsTopmost}"
						Toggled="cb_topMost_Toggled" />
					<Slider
						Grid.Column="1"
						Margin="5,0"
						Minimum="0"
						Maximum="100"
						Value="{Binding Volume}"
						ToolTip="{Binding Volume}" />
					<Button
						Grid.Column="2"
						Name="btn_Edit"
						VerticalAlignment="Center"
						Height="26"
						Content="{Binding EdittingText}"
						Click="btn_Edit_Click"
						Foreground="White"
						Background="#33FFFFFF"
						BorderThickness="0"
						FontSize="11" />
				</Grid>
				<Grid Row="1" Margin="0,3,0,0">
					<StackPanel
						Orientation="Horizontal"
						VerticalAlignment="Center"
						HorizontalAlignment="Left">
						<Button
							Name="btn_group1"
							Content="Hiệu ứng"
							Style="{StaticResource GroupButtonStyle}"
							Background="#1E88E5"
							Click="btn_group1_Click" />
						<Button
							Name="btn_group2"
							Content="Nhạc 1"
							Style="{StaticResource GroupButtonStyle}"
							Background="#43A047"
							Click="btn_group2_Click" />
						<Button
							Name="btn_group3"
							Content="Nhạc 2"
							Style="{StaticResource GroupButtonStyle}"
							Background="#FB8C00"
							Click="btn_group3_Click" />
					</StackPanel>
					<Button
						Name="btn_Cancel"
						HorizontalAlignment="Right"
						Width="60"
						Height="26"
						VerticalAlignment="Center"
						Click="btn_Cancel_Click"
						Background="#33FFFFFF"
						BorderThickness="0"
						Foreground="White">
						<Grid>
							<TextBlock
								Text="Dừng"
								Visibility="{Binding IsEditting, Converter={StaticResource BooleanTrueToHiddenConverter}}" />
							<TextBlock
								Text="{Binding StopHotKey}"
								Visibility="{Binding IsEditting, Converter={StaticResource BooleanFalseToHiddenConverter}}"
								ToolTip="{Binding StopHotKey}" />
						</Grid>
					</Button>
				</Grid>
			</Grid>
		</Border>

		<Grid Row="1">
			<ItemsControl
				Margin="3,5"
				Background="Transparent"
				ItemsSource="{Binding Effects}"
				Visibility="{Binding IsEditting, Converter={StaticResource BooleanTrueToHiddenConverter}}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<UniformGrid Columns="3" Rows="7" />
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Button
							Name="btn_PlaySound"
							Style="{StaticResource EffectButtonStyle}"
							Content="{Binding Name}"
							ToolTip="{Binding Name}"
							ClickMode="Press"
							Click="btn_PlaySound_Click"
							Background="#1E88E5" />
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
			<ListView
				Name="lv_gridEffect"
				Margin="5"
				Background="{DynamicResource MahApps.Brushes.ControlBackground}"
				BorderBrush="#DDDDDD"
				ItemsSource="{Binding Effects}"
				Visibility="{Binding IsEditting, Converter={StaticResource BooleanFalseToHiddenConverter}}">
				<ListView.View>
					<GridView>
						<GridViewColumn Header="Tên" Width="90">
							<GridViewColumn.CellTemplate>
								<DataTemplate>
									<WpfUiControls:TextBlockEdit
										Text="{Binding Name}"
										MouseDown="TextBlockEdit_MouseDown" />
								</DataTemplate>
							</GridViewColumn.CellTemplate>
						</GridViewColumn>
						<GridViewColumn Header="Đường dẫn" Width="90">
							<GridViewColumn.CellTemplate>
								<DataTemplate>
									<StackPanel Orientation="Horizontal">
										<Button
											Name="btn_selectFile"
											Width="30"
											Content="..."
											Click="btn_selectFile_Click" />
										<TextBlock
											TextWrapping="NoWrap"
											VerticalAlignment="Center"
											Margin="3,0,0,0"
											Text="{Binding SoundFilePath}"
											ToolTip="{Binding SoundFilePath}" />
									</StackPanel>
								</DataTemplate>
							</GridViewColumn.CellTemplate>
						</GridViewColumn>
						<GridViewColumn Header="Hotkey" Width="100">
							<GridViewColumn.CellTemplate>
								<DataTemplate>
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition />
											<ColumnDefinition Width="75" />
										</Grid.ColumnDefinitions>
										<TextBlock
											Grid.Column="0"
											VerticalAlignment="Center"
											Text="{Binding Key}"
											ToolTip="{Binding Key}" />
										<Button
											Name="btn_register"
											Grid.Column="1"
											Content="Key"
											Height="22"
											FontSize="11"
											Click="btn_register_Click" />
									</Grid>
								</DataTemplate>
							</GridViewColumn.CellTemplate>
						</GridViewColumn>
					</GridView>
				</ListView.View>
				<FrameworkElement.ContextMenu>
					<ContextMenu ItemsSource="{Binding EffectsMenus}">
						<FrameworkElement.Resources>
							<ResourceDictionary>
								<ControlTemplate x:Key="MenuSeparatorTemplate">
									<Separator IsEnabled="False" />
								</ControlTemplate>
							</ResourceDictionary>
						</FrameworkElement.Resources>
						<ItemsControl.ItemContainerStyle>
							<Style TargetType="{x:Type MenuItem}">
								<Setter Property="Header" Value="{Binding Text}" />
								<EventSetter Event="Click" Handler="EffectsMenus_click" />
								<Style.Triggers>
									<DataTrigger Binding="{Binding}" Value="{x:Null}">
										<Setter Property="Template" Value="{StaticResource MenuSeparatorTemplate}" />
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</ItemsControl.ItemContainerStyle>
					</ContextMenu>
				</FrameworkElement.ContextMenu>
				<ItemsControl.ItemContainerStyle>
					<Style TargetType="{x:Type ListViewItem}">
						<Setter Property="HorizontalContentAlignment" Value="Stretch" />
						<Setter Property="Focusable" Value="False" />
					</Style>
				</ItemsControl.ItemContainerStyle>
			</ListView>
		</Grid>

		<Border Grid.Row="2"
			Background="{DynamicResource MahApps.Brushes.Accent}">
			<TextBlock
				Text="© 2026 SOUND EFFECT PRO"
				Foreground="White"
				FontSize="11"
				HorizontalAlignment="Center"
				VerticalAlignment="Center" />
		</Border>
	</Grid>
</mah:MetroWindow>
