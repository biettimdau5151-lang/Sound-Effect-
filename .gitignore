## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Vv][Ss][Pp][Ss][Cc][Cc]/

# Visual Studio 2015/2017 cache/options directory
.vs/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml

# Build Performance Diagnostics
*.psess
*.vsp
*.vspx
*.sap

# Visual Studio Profiler
*.nmw
*.etl
*.pdata

# Core dotnet artifacts
project.lock.json
project.fragment.lock.json
artifacts/

# StyleCop
StyleCopReport.xml

# Files built by Visual Studio
*_i.c
*_p.c
*_h.h
*.res
*.tlb
*.tli
*.tlh
*.tmp
*.rsp
*.pgc
*.pgd
*.compview
*.spec
*.ncb
*.opensln
*.sdf
*.cachefile
*.VC.db
*.VC.opendb

# Visual Studio Server Explorer data
*.ntvs_analysis.dat

# Visual Studio analyzer working directory
*.vshost.exe
*.vshost.exe.config
*.vshost.exe.manifest

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/packages/*
# except build/, which is used as an MSBuild target.
!**/packages/build/
# Uncomment if using NuGet 4.x+ with PackageReference
# !**/packages/

# Others
.DS_Store
*.swp
*.lock
*.geminiignore
.gemini/
